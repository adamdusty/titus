{
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON",
                "CMAKE_CXX_EXTENSIONS": "OFF",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_CXX_SCAN_FOR_MODULES": "OFF"
            }
        },
        {
            "name": "ci",
            "inherits": "base",
            "cacheVariables": {
                "BUILD_TESTING": "ON",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "ci-dbg",
            "configurePreset": "ci",
            "configuration": "Debug"
        },
        {
            "name": "ci-rel",
            "configurePreset": "ci",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "ci-dbg",
            "configuration": "Debug",
            "configurePreset": "ci",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ci-rel",
            "configuration": "Release",
            "configurePreset": "ci",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}